# entrypoint.c only needs R headers now; HDF5 headers not required.
PKG_CFLAGS =

TARGET_DIR = ./rust/target
LIBDIR     = $(TARGET_DIR)/release
STATLIB    = $(LIBDIR)/libpicklerick_r.a

# Dynamic system HDF5.  On Ubuntu/Debian HDF5 lives in a non-standard path;
# use pkg-config to get the right -L and -l flags.
HDF5_LIBS  = $(shell pkg-config --libs hdf5 2>/dev/null || echo "-L/usr/lib/x86_64-linux-gnu/hdf5/serial -lhdf5")
PKG_LIBS   = $(STATLIB) $(HDF5_LIBS) -lz -ldl -lm

$(SHLIB): $(STATLIB)

$(STATLIB):
	cargo build --lib --release --manifest-path=./rust/Cargo.toml

clean:
	rm -Rf $(SHLIB) $(STATLIB) $(TARGET_DIR)
